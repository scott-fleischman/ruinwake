{
  "permissions": {
    "allow": [
      "Bash(source ~/.nvm/nvm.sh && nvm use *)",
      "Bash(npx vitest *)",
      "Bash(npx vite *)",
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(git rm *)",
      "Bash(cp -r *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(cat *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "if": "Bash(git commit *)",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/deploy-gh-pages.sh"
          }
        ]
      }
    ]
  }
}
